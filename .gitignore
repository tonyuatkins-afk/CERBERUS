# CERBERUS runtime output (commit samples under samples/ instead)
CERBERUS.INI

# Sneaker-net drop folder — convenience copies of EXE + PHASE*.BAT.
# Source of truth is the top-level build + tests/target/. Rebuild by
# running `wmake` and `cp CERBERUS.EXE dist/`.
dist/

# DOSBox-X smoke-test runtime artifacts (dev/ convention).
# The smoketest.conf IS tracked; its outputs are not.
devenv/SMOKE.INI
devenv/SMOKE.LOG
devenv/SMOKE.RC
runs/

# CERBERUS smoketest artifacts (devenv/)
devenv/*.INI
devenv/*.LOG
devenv/*.RC
devenv/*.MARK
devenv/*.CSV
devenv/*.TMP

# Stale shell-redirect artifacts. Anchored to repo root with leading /
# so tracked captures under tests/captures/ are not matched. Git on
# Windows is case-insensitive by default so plain `CAPTURE.INI` without
# the root anchor catches `capture.ini` under captures/, which is wrong.
/CERBERUS.LAS
/CERBERUS.LAST
/CERBERUS.UNK
/UPLOAD.TMP
/CAPTURE.INI
/cerberus.map

# Investigation-branch binary; not tagged, not released
/dist-investigation/
